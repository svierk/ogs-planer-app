{
  "name": "ogs-planer-app",
  "version": "1.4.0",
  "description": "Planungstool für den Ganztagsbereich einer Grundschule",
  "author": {
    "name": "Sebastiano Schwarz",
    "url": "https://github.com/svierk"
  },
  "license": "MIT",
  "engines": {
    "node": "24.x.x",
    "npm": "11.x.x"
  },
  "main": "main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "electron": "ng build && electron .",
    "rebuild": "./node_modules/.bin/electron-rebuild",
    "make": "ng build && electron-forge make",
    "package": "ng build && electron-forge package",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:once": "ng test --watch=false",
    "test:coverage": "ng test --watch=false --code-coverage",
    "test:ci": "ng test --browsers CIChromeHeadless --watch=false --code-coverage",
    "lint": "ng lint --max-warnings 0",
    "lint:fix": "ng lint --fix",
    "prettier": "prettier \"**/*.(ts|scss|html|js|json|yaml|yml)\" --check",
    "prettier:fix": "prettier \"**/*.(ts|scss|html|js|json|yaml|yml)\" --write",
    "precommit": "lint-staged; npm run lint",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,scss,html}": [
      "npm run prettier"
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.5",
    "@angular/cdk": "^22.0.3",
    "@angular/common": "^22.0.5",
    "@angular/compiler": "^22.0.5",
    "@angular/core": "^22.0.5",
    "@angular/forms": "^22.0.5",
    "@angular/material": "^22.0.3",
    "@angular/platform-browser": "^22.0.5",
    "@angular/platform-browser-dynamic": "^22.0.5",
    "@angular/router": "^22.0.5",
    "better-sqlite3": "^12.11.1",
    "bootstrap": "^5.3.3",
    "electron-squirrel-startup": "^1.0.1",
    "rxjs": "~7.8.1",
    "tslib": "^2.7.0",
    "xlsx-js-style": "^1.2.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^22.0.0",
    "@angular-eslint/eslint-plugin": "^22.0.0",
    "@angular-eslint/eslint-plugin-template": "^22.0.0",
    "@angular-eslint/schematics": "^22.0.0",
    "@angular-eslint/template-parser": "^22.0.0",
    "@angular/build": "^22.0.5",
    "@angular/cli": "^22.0.5",
    "@angular/compiler-cli": "^22.0.5",
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron/rebuild": "^4.1.0",
    "@types/bootstrap": "^5.2.11",
    "@types/jasmine": "^6.0.0",
    "@types/node": "^26.1.0",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.57.0",
    "electron": "^41.9.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jasmine": "^4.2.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-rxjs": "^5.0.3",
    "husky": "^9.1.6",
    "jasmine-core": "^6.3.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "^2.2.0",
    "karma-junit-reporter": "^2.0.1",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "typescript": "~5.9.3"
  }
}
